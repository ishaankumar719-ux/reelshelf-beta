EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Required to run scripts/generate-seed-data.ts (dev only — not used at runtime)
EXPO_PUBLIC_TMDB_API_KEY=your-tmdb-api-key-here
# GIF search/trending in the review composer's attachment picker (mirrors the
# website's NEXT_PUBLIC_GIPHY_API_KEY — same provider, same endpoints). Missing
# from this environment on BOTH platforms today — see
# WEBSITE_ATTACHMENT_SYSTEM_AUDIT.md §5. Without a real key, the GIF picker
# behaves exactly like the website's own real empty-key state (silently empty
# results), not an error.
EXPO_PUBLIC_GIPHY_API_KEY=your-giphy-api-key-here
# Crash reporting (lib/observability/sentry.ts). No-ops with a console notice
# when unset — get a DSN from sentry.io, create a React Native project.
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
# Product analytics (lib/observability/analytics.ts). No-ops with a console
# notice when unset. PostHog chosen as the default: self-hostable, generous
# free tier, first-class React Native SDK — swap for another provider here if
# preferred, the lib/observability/analytics.ts call sites don't need to change.
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-project-api-key-here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
